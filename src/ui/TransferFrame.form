<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="ui.TransferFrame">
  <grid id="27dc6" binding="transferFrame" layout-manager="GridLayoutManager" row-count="8" column-count="2" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="10" left="10" bottom="10" right="10"/>
    <constraints>
      <xy x="20" y="20" width="500" height="400"/>
    </constraints>
    <properties>
      <background color="-15132132"/>
      <foreground color="-15132132"/>
    </properties>
    <border type="none"/>
    <children>
      <component id="c4bcc" class="javax.swing.JLabel" binding="lbl_main_label">
